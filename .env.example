# Port d'écoute du serveur (défaut : 3000)
PORT=3000

# Nom du fichier SQLite dans server/data/ (défaut : dig.sqlite)
DB_FILE=dig.sqlite

# Secret de session (obligatoire en production — changer cette valeur !)
SESSION_SECRET=dig-dev-secret-change-in-prod

# Clé d'accès au panel admin (obligatoire pour activer /api/admin/*)
ADMIN_SECRET=change-me-in-prod
